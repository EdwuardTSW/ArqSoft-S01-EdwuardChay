<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dk Agencia Distribuidora de Motos</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Catalogo.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400..900&display=swap" rel="stylesheet" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-sm app-navbar">
            <div class="container">
                <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">DK</span>
                    <span>Dk Motos</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Abrir navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav ms-auto align-items-sm-center gap-sm-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-cta" asp-area="" asp-controller="Catalogo" asp-action="Index">Catálogo 2026</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-brand">
                    <span class="brand-mark brand-mark-sm">DK</span>
                    <strong>Dk Agencia Distribuidora de Motos</strong>
                </div>
                <div class="footer-links">
                    <a asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                    <a asp-area="" asp-controller="Catalogo" asp-action="Index">Catálogo</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
                </div>
                <span class="footer-copy">&copy; 2026 - Dk Agencia Distribuidora de Motos. Todos los derechos reservados.</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
